<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="680.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uacm.pf.farmaplus.ProductosController">
   <children>
      <Label layoutX="20.0" layoutY="20.0" text="Gestion de Productos">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>

      <AnchorPane layoutX="20.0" layoutY="60.0" prefHeight="520.0" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
         <children>
            
            <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#e4e4e4" height="80.0" layoutX="65.0" layoutY="14.0" stroke="#ababab" strokeType="INSIDE" width="90.0" />
            <Button layoutX="60.0" layoutY="100.0" mnemonicParsing="false" prefHeight="25.0" prefWidth="100.0" style="-fx-background-color: #e0e0e0; -fx-cursor: hand;" text="Subir Imagen">
               <font>
                  <Font size="11.0" />
               </font>
            </Button>

            <VBox layoutX="15.0" layoutY="135.0" prefHeight="250.0" prefWidth="190.0" spacing="5.0">
               <children>
                  <Label text="SKU (Codigo):">
                     <font><Font name="System Bold" size="12.0" /></font>
                  </Label>
                  <TextField fx:id="txtId" promptText="Ej. 750123456" />
                  
                  <Label text="Nombre:" />
                  <TextField fx:id="txtNombre" promptText="Ej. Paracetamol 500mg" />
                  
                  <Label text="Marca:" />
                  <TextField fx:id="txtMarca" promptText="Ej. Generico" />
                  
                  <Label text="Precio ($):" />
                  <TextField fx:id="txtPrecio" promptText="0.00" />
                  
                  <Label text="Stock:" />
                  <TextField fx:id="txtStock" promptText="0" />
               </children>
            </VBox>
            
            <Button layoutX="15.0" layoutY="410.0" mnemonicParsing="false" onAction="#guardarProducto" prefHeight="35.0" prefWidth="190.0" style="-fx-background-color: #449d6b; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" text="AGREGAR PRODUCTO" />
            <Button layoutX="15.0" layoutY="455.0" mnemonicParsing="false" onAction="#actualizarProducto" prefHeight="25.0" prefWidth="90.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-cursor: hand;" text="Actualizar" />
            <Button layoutX="115.0" layoutY="455.0" mnemonicParsing="false" onAction="#eliminarProducto" prefHeight="25.0" prefWidth="90.0" style="-fx-background-color: #ff4d5f; -fx-text-fill: white; -fx-cursor: hand;" text="Eliminar" />
            <Button layoutX="15.0" layoutY="485.0" mnemonicParsing="false" onAction="#limpiarCampos" prefHeight="25.0" prefWidth="190.0" style="-fx-background-color: #9e9e9e; -fx-text-fill: white; -fx-cursor: hand;" text="Limpiar Campos" />
         </children>
      </AnchorPane>

      <TableView fx:id="tablaProductos" layoutX="260.0" layoutY="60.0" prefHeight="520.0" prefWidth="400.0" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
        <columns>
          <TableColumn fx:id="colId" prefWidth="70.0" text="SKU" />
          <TableColumn fx:id="colNombre" prefWidth="130.0" text="Nombre" />
            <TableColumn fx:id="colMarca" prefWidth="90.0" text="Marca" />
            <TableColumn fx:id="colPrecioProd" prefWidth="60.0" text="Precio" />
            <TableColumn fx:id="colStock" prefWidth="50.0" text="Stock" />
        </columns>
      </TableView>
   </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="680.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uacm.pf.farmaplus.VentasController">
   <children>
      <Label layoutX="20.0" layoutY="20.0" text="Punto de Venta">
         <font>
            <Font name="SansSerif Bold" size="24.0" />
         </font>
      </Label>

      <AnchorPane layoutX="20.0" layoutY="60.0" prefHeight="70.0" prefWidth="400.0" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
         <children>
            <TextField fx:id="txtBuscarProducto" layoutX="14.0" layoutY="22.0" prefHeight="26.0" prefWidth="280.0" promptText="Buscar producto por nombre o codigo..." />
            <Button layoutX="310.0" layoutY="22.0" mnemonicParsing="false" onAction="#agregarAlCarrito" style="-fx-background-color: #449d6b; -fx-text-fill: white; -fx-cursor: hand;" text="Agregar" />
         </children>
      </AnchorPane>

      <TableView fx:id="tablaCarrito" layoutX="20.0" layoutY="145.0" prefHeight="435.0" prefWidth="400.0" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
        <columns>
          <TableColumn fx:id="colProducto" prefWidth="180.0" text="Producto" />
          <TableColumn fx:id="colCantidad" prefWidth="70.0" text="Cant." />
            <TableColumn fx:id="colPrecio" prefWidth="75.0" text="Precio" />
            <TableColumn fx:id="colSubtotal" prefWidth="75.0" text="Subtotal" />
        </columns>
      </TableView>

      <AnchorPane layoutX="435.0" layoutY="60.0" prefHeight="520.0" prefWidth="225.0" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
         <children>
            <Label layoutX="15.0" layoutY="15.0" text="Cliente / Membresia">
               <font>
                  <Font name="SansSerif Bold" size="14.0" />
               </font>
            </Label>
            <ComboBox fx:id="comboClientes" layoutX="15.0" layoutY="40.0" prefHeight="26.0" prefWidth="195.0" promptText="Seleccionar Cliente..." />
            <Label fx:id="lblMembresia" layoutX="15.0" layoutY="75.0" text="Sin membresia (0%)" textFill="#8a8a8a" />

            <VBox layoutX="15.0" layoutY="310.0" prefHeight="100.0" prefWidth="195.0" spacing="10.0">
               <children>
                  <Label text="Subtotal: $0.00">
                     <font>
                        <Font name="SansSerif Regular" size="16.0" />
                     </font>
                  </Label>
                  <Label text="Descuento: $0.00" textFill="#e12e2e">
                     <font>
                        <Font name="SansSerif Regular" size="16.0" />
                     </font>
                  </Label>
                  <Label text="Total: $0.00" textFill="#449d6b">
                     <font>
                        <Font name="SansSerif Bold" size="22.0" />
                     </font>
                  </Label>
               </children>
            </VBox>

            <Button layoutX="15.0" layoutY="450.0" mnemonicParsing="false" onAction="#completarVenta" prefHeight="45.0" prefWidth="195.0" style="-fx-background-color: linear-gradient(to bottom right, #449d6b, #633364); -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5px;" text="COMPLETAR VENTA">
               <font>
                  <Font size="14.0" />
               </font>
            </Button>
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="680.0"
            style="-fx-background-color: #f4f4f4;"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.uacm.pf.farmaplus.controlador.ProductosController">

   <children>

      <!-- TITULO -->
      <Label layoutX="20.0" layoutY="20.0" text="Gestion de Productos">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>

      <!-- PANEL FORMULARIO -->
      <AnchorPane layoutX="20.0" layoutY="60.0"
                  prefHeight="520.0" prefWidth="220.0"
                  style="-fx-background-color: white; -fx-background-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">

         <children>

            <!-- IMAGEN -->
            <ImageView fx:id="imgPreview"
                       fitHeight="80.0"
                       fitWidth="90.0"
                       layoutX="65.0"
                       layoutY="14.0"
                       preserveRatio="true" />

            <!-- BOTON IMAGEN -->
            <Button layoutX="60.0" layoutY="100.0"
                    onAction="#subirImagen"
                    prefHeight="25.0"
                    prefWidth="100.0"
                    style="-fx-background-color: #e0e0e0; -fx-cursor: hand;"
                    text="Subir Imagen">
               <font>
                  <Font size="11.0" />
               </font>
            </Button>

            <!-- FORMULARIO -->
            <VBox layoutX="15.0" layoutY="135.0"
                  prefHeight="250.0" prefWidth="190.0"
                  spacing="5.0">

               <children>

                  <Label text="SKU (Codigo):">
                     <font><Font name="System Bold" size="12.0" /></font>
                  </Label>
                  <TextField fx:id="txtId" promptText="Ej. 750123456" />

                  <Label text="Nombre:" />
                  <TextField fx:id="txtNombre" promptText="Ej. Paracetamol 500mg" />

                  <Label text="Marca:" />
                  <TextField fx:id="txtMarca" promptText="Ej. Generico" />

                  <Label text="Precio ($):" />
                  <TextField fx:id="txtPrecio" promptText="0.00" />

                  <Label text="Stock:" />
                  <TextField fx:id="txtStock" promptText="0" />

               </children>
            </VBox>

            <!-- BOTONES -->
            <Button layoutX="15.0" layoutY="410.0"
                    onAction="#guardarProducto"
                    prefHeight="35.0" prefWidth="190.0"
                    style="-fx-background-color: #449d6b; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;"
                    text="AGREGAR PRODUCTO" />

            <Button layoutX="15.0" layoutY="455.0"
                    onAction="#actualizarProducto"
                    prefHeight="25.0" prefWidth="90.0"
                    style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-cursor: hand;"
                    text="Actualizar" />

            <Button layoutX="115.0" layoutY="455.0"
                    onAction="#eliminarProducto"
                    prefHeight="25.0" prefWidth="90.0"
                    style="-fx-background-color: #ff4d5f; -fx-text-fill: white; -fx-cursor: hand;"
                    text="Eliminar" />

            <Button layoutX="15.0" layoutY="485.0"
                    onAction="#limpiarCampos"
                    prefHeight="25.0" prefWidth="190.0"
                    style="-fx-background-color: #9e9e9e; -fx-text-fill: white; -fx-cursor: hand;"
                    text="Limpiar Campos" />

         </children>
      </AnchorPane>

      <!-- TABLA -->
      <TableView fx:id="tablaProductos"
                 layoutX="260.0" layoutY="60.0"
                 prefHeight="520.0" prefWidth="400.0"
                 style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">

         <columns>
            <TableColumn fx:id="colId" text="SKU" prefWidth="70.0" />
            <TableColumn fx:id="colNombre" text="Nombre" prefWidth="130.0" />
            <TableColumn fx:id="colMarca" text="Marca" prefWidth="90.0" />
            <TableColumn fx:id="colPrecioProd" text="Precio" prefWidth="60.0" />
            <TableColumn fx:id="colStock" text="Stock" prefWidth="50.0" />
         </columns>

      </TableView>

   </children>
</AnchorPane>
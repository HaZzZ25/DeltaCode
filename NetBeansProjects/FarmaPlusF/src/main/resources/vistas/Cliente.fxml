<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="680.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uacm.pf.farmaplus.controlador.ClientesController">
   <children>
      <Label layoutX="20.0" layoutY="20.0" text="Gestion de Clientes y Membresias">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>

      <AnchorPane layoutX="20.0" layoutY="60.0" prefHeight="520.0" prefWidth="220.0" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
         <children>
            <VBox layoutX="15.0" layoutY="30.0" prefHeight="350.0" prefWidth="190.0" spacing="10.0">
               <children>
                  <TextField fx:id="txtId" visible="false" managed="false" />
                  
                  <Label text="Nombre Completo:">
                     <font><Font name="System Bold" size="12.0" /></font>
                  </Label>
                  <TextField fx:id="txtNombre" promptText="Ej. Juan Perez" />
                  
                  <Label text="Telefono:" />
                  <TextField fx:id="txtTelefono" promptText="Ej. 5512345678" />
                  
                  <Label text="Correo Electronico:" />
                  <TextField fx:id="txtCorreo" promptText="correo@ejemplo.com" />
                  
                  <Label text="Nivel de Membresia:" />
                  <ComboBox fx:id="comboMembresia" prefWidth="190.0" promptText="Seleccionar..." />
                  
                  <Label text="* El descuento se calcula solo" textFill="#868686">
                     <font>
                        <Font size="10.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
            
            <Button layoutX="15.0" layoutY="410.0" mnemonicParsing="false" onAction="#guardarCliente" prefHeight="35.0" prefWidth="190.0" style="-fx-background-color: #633364; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" text="REGISTRAR CLIENTE" />
            <Button layoutX="15.0" layoutY="455.0" mnemonicParsing="false" onAction="#actualizarCliente" prefHeight="25.0" prefWidth="90.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-cursor: hand;" text="Actualizar" />
            <Button layoutX="115.0" layoutY="455.0" mnemonicParsing="false" onAction="#eliminarCliente" prefHeight="25.0" prefWidth="90.0" style="-fx-background-color: #ff4d5f; -fx-text-fill: white; -fx-cursor: hand;" text="Eliminar" />
            <Button layoutX="15.0" layoutY="485.0" mnemonicParsing="false" onAction="#limpiarCampos" prefHeight="25.0" prefWidth="190.0" style="-fx-background-color: #9e9e9e; -fx-text-fill: white; -fx-cursor: hand;" text="Limpiar Campos" />
         </children>
      </AnchorPane>

      <TableView fx:id="tablaClientes" layoutX="260.0" layoutY="60.0" prefHeight="520.0" prefWidth="400.0" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
        <columns>
          <TableColumn fx:id="colNombre" prefWidth="120.0" text="Nombre" />
          <TableColumn fx:id="colTelefono" prefWidth="80.0" text="Telefono" />
          <TableColumn fx:id="colMembresia" prefWidth="100.0" text="Membresia" />
          <TableColumn fx:id="colDescuento" prefWidth="80.0" text="Desc (%)" />
        </columns>
      </TableView>
   </children>
</AnchorPane>